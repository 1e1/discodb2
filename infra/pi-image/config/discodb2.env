# discodb2 Pi provisioning — single source of truth for first-boot config.
#
# Copied to /etc/discodb2/discodb2.env by install.sh and sourced by every
# provisioning script and systemd unit. Edit BEFORE flashing, or edit on the
# Pi and re-run the units (systemctl restart discodb2-*).
#
# Plain `KEY=value` (no spaces, no quotes needed by systemd EnvironmentFile).

# ── CAN bus ────────────────────────────────────────────────────────────────
# Bitrate of the vehicle bus you sniff. VW PQ powertrain is typically 500000;
# comfort/infotainment buses are often 100000. (See ___doc___.md.)
CAN_BITRATE=500000
# Interface name. The in-kernel gs_usb driver presents candleLight/UCAN as can0.
CAN_IFACE=can0
# LISTEN-ONLY is NON-NEGOTIABLE for read-only RE (DESIGN §4.1). This brings the
# interface up in listen-only at the link layer too, as defence-in-depth — the
# backend ALSO enforces it. Leave =1 unless you deliberately need to transmit.
CAN_LISTEN_ONLY=1

# ── WiFi access point (WPA2 — open WiFi is rejected, DESIGN §8) ──────────────
AP_SSID=discodb2
# WPA2 passphrase: 8..63 ASCII chars. CHANGE THIS before flashing.
AP_PASSPHRASE=changeme-discodb2
# 2.4 GHz channel (1/6/11 are non-overlapping). The TP-Link dongle below is
# 2.4 GHz; Pi 3B+ onboard radio also supports 5 GHz but we stay portable.
AP_CHANNEL=6
# Two-letter regulatory domain (sets legal channels/power). EU example: FR/DE.
AP_COUNTRY=FR
# Fixed AP address + DHCP pool handed to phones/laptops.
AP_ADDR=192.168.4.1
AP_NETMASK=255.255.255.0
AP_DHCP_START=192.168.4.50
AP_DHCP_END=192.168.4.150
# Wireless interface to run the AP on. Onboard Pi radio is wlan0; a USB dongle
# (e.g. the TP-Link below on a Pi 1B+) often enumerates as wlan1 — set it here.
AP_IFACE=wlan0

# ── Backend service ──────────────────────────────────────────────────────────
# Where the repo is deployed on the Pi (install.sh clones/copies here).
DISCODB2_HOME=/opt/discodb2
# Backend WebSocket port (DESIGN §3.1 default).
BACKEND_PORT=8765
# Source the backend opens on boot. "sim" needs zero hardware and is the safe
# default for first boot; switch to "socketcan" once can0 is wired and verified.
BACKEND_SOURCE=socketcan
# Python interpreter inside the backend venv (created by install.sh).
BACKEND_PYTHON=/opt/discodb2/.venv/bin/python

# ── LAN service discovery (mDNS via the OS Avahi responder) ──────────────────
# The SYSTEM avahi-daemon advertises the backend so clients reach the box at
# http://<MDNS_HOSTNAME>.local:<BACKEND_PORT> (and ws on the same host) without
# typing the AP IP. This is the OS responder — NOT backend code, event-driven,
# idle on the hot path (safe on a Pi 1B+). The fixed AP_ADDR above is always the
# works-everywhere fallback. avahi-setup.sh pins this as Avahi's host-name; it
# does NOT change the system hostname. Keep it short, lowercase, no dots.
MDNS_HOSTNAME=discodb
